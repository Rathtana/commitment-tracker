# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# As of late-2025, Supabase emits the new "publishable key" format (sb_publishable_*)
# instead of the legacy JWT-shaped "anon" key. Either format works with @supabase/ssr.
# Populate BOTH names with the same value so downstream code using either convention works.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Postgres connection — Project Settings → Database → Transaction pooler (port 6543)
# Append ?pgbouncer=true&connection_limit=1
DATABASE_URL=
